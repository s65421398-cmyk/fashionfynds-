# Database Configuration (Already configured)
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# Authentication (Already configured)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ============================================
# ANALYTICS & TRACKING CONFIGURATION
# ============================================

# Google Analytics 4
# How to get: Google Analytics → Admin → Property → Data Streams → Web → Measurement ID
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=

# Google Tag Manager (Optional - for advanced tracking)
# How to get: tagmanager.google.com → Account → Container → GTM ID shown in top-right
# Format: GTM-XXXXXX
NEXT_PUBLIC_GTM_ID=

# Google Ads Conversion Tracking
# How to get: Google Ads → Tools → Conversions → View tag setup → Conversion ID
# Format: AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Facebook Pixel
# How to get: Meta Business Manager → Events Manager → Pixels → Your Pixel ID
# Format: 123456789012345 (15-digit number)
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=

# Hotjar Analytics & Heatmaps
# How to get: Hotjar dashboard → Site Settings → Tracking code → Site ID from script tag
# Format: 1234567 (7-digit number)
NEXT_PUBLIC_HOTJAR_ID=

# ============================================
# TRACKING SETUP INSTRUCTIONS
# ============================================

# 1. GOOGLE ANALYTICS 4 (GA4)
#    - Go to: https://analytics.google.com
#    - Create account → Create property → Set up data stream (Web)
#    - Copy the Measurement ID (starts with G-)
#    - Paste above in NEXT_PUBLIC_GA4_ID

# 2. GOOGLE TAG MANAGER (Optional)
#    - Go to: https://tagmanager.google.com
#    - Create account → Create container (Web)
#    - Copy the Container ID (starts with GTM-)
#    - Paste above in NEXT_PUBLIC_GTM_ID

# 3. GOOGLE ADS CONVERSION TRACKING
#    - Go to: https://ads.google.com
#    - Tools & Settings → Measurement → Conversions
#    - Create new conversion action → Website
#    - Copy the Conversion ID (starts with AW-)
#    - Paste above in NEXT_PUBLIC_GOOGLE_ADS_ID

# 4. FACEBOOK PIXEL
#    - Go to: https://business.facebook.com/events_manager
#    - Connect Data Sources → Web → Facebook Pixel
#    - Create or select existing pixel
#    - Copy the Pixel ID (15-digit number)
#    - Paste above in NEXT_PUBLIC_FACEBOOK_PIXEL_ID

# 5. HOTJAR
#    - Go to: https://www.hotjar.com
#    - Create account → Add new site
#    - Copy the Site ID from tracking code
#    - Paste above in NEXT_PUBLIC_HOTJAR_ID
