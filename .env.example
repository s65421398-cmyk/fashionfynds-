# Database Configuration
TURSO_CONNECTION_URL=your_turso_connection_url_here
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Authentication
BETTER_AUTH_SECRET=your_generated_secret_here

# Email Service (Resend)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
# From email address (use onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=FashionFynds <orders@fashionfynds.com>
# Reply-to address
RESEND_REPLY_TO=support@fashionfynds.com

# Analytics (Optional - for tracking and analytics)
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=123456789012345
NEXT_PUBLIC_HOTJAR_ID=1234567

# Application URL (Optional - for email links)
NEXT_PUBLIC_APP_URL=https://fashionfynds.com